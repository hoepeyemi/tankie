{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "tooonks3d",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create Blast Tanks Game",
        "description": "Create a new Blast Tanks multiplayer post",
        "location": "subreddit",
        "forUserType": "user",
        "endpoint": "/internal/menu/create-post"
      }
    ]
  },
  "payments": {
    "endpoints": {
      "fulfillOrder": "/internal/payments/fulfill"
    },
    "products": [
      {
        "sku": "skin_military",
        "displayName": "Soldier Boy Tank",
        "description": "Unlock the Soldier Boy tank skin for Blast Tanks",
        "price": 5,
        "accountingType": "INSTANT"
      },
      {
        "sku": "skin_studystorm",
        "displayName": "StudyStorm Tank",
        "description": "Unlock the StudyStorm tank skin for Blast Tanks",
        "price": 25,
        "accountingType": "INSTANT"
      },
      {
        "sku": "skin_weeb",
        "displayName": "Weeb Kawaii Tank",
        "description": "Unlock the Weeb Kawaii tank skin for Blast Tanks",
        "price": 50,
        "accountingType": "INSTANT"
      },
      {
        "sku": "skin_thomas",
        "displayName": "Thomas The Tank",
        "description": "Unlock the Thomas The Tank skin for Blast Tanks",
        "price": 100,
        "accountingType": "INSTANT"
      }
    ]
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "tankie3d_dev"
  }
}
